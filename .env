APP_NAME="Online Quiz System"
APP_URL="http://localhost/WEBPROJE/public"
APP_ENV="development"

# Database Configuration
DB_HOST="localhost"
DB_NAME="quiz_system_db"
DB_USER="root"
DB_PASS=""

# Mailtrap Configuration (SMTP)
MAIL_HOST="sandbox.smtp.mailtrap.io"
MAIL_PORT="2525"
MAIL_USERNAME="your_mailtrap_username"
MAIL_PASSWORD="your_mailtrap_password"
MAIL_FROM_ADDRESS="noreply@quizsystem.local"
MAIL_FROM_NAME="Quiz System"

# Security Settings
SESSION_LIFETIME=120 # In minutes
STRICT_EXAM_MODE=false # Set true for production
